# ============================================================
#                     .gitignore
# ============================================================

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Node.js ────────────────────────────────────────────────
node_modules/
dist/
build/
.npm
.node_repl_history
*.tgz
.yarn-integrity
.pnp.*
.yarn/

# ─── Python ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
.env
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.egg-info/
dist/
*.egg
.mypy_cache/
.dmypy.json

# ─── Environment & Secrets ──────────────────────────────────
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
secrets/
config/secrets.*

# ─── IDEs & Editors ─────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Java ───────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
target/
.gradle/
build/

# ─── Android ────────────────────────────────────────────────
*.apk
*.ap_
local.properties
.gradle

# ─── iOS / macOS ────────────────────────────────────────────
*.xcworkspace
*.xcuserdata
DerivedData/
*.ipa
Pods/

# ─── Docker ─────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─── Terraform ──────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# ─── Compiled / Binary ──────────────────────────────────────
*.exe
*.dll
*.so
*.dylib
*.out
*.o
*.a

# ─── Archives ───────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z

# ─── Databases ──────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ─── Misc ───────────────────────────────────────────────────
.cache/
.temp/
tmp/
temp/
coverage/
.nyc_output/